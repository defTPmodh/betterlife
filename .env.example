# Better Life live environment template
# Copy this file to .env.local for local development.
# In production, add these variables in your hosting provider dashboard.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Better Life
NEXT_PUBLIC_ENVIRONMENT=development

# PostgreSQL database
# Example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this to the browser or prefix it with NEXT_PUBLIC_.
# Only use inside backend/API routes if you need admin-level Supabase operations.
SUPABASE_SERVICE_ROLE_KEY=

# Auth and session security
# Generate with: openssl rand -base64 32
AUTH_SECRET=
SESSION_COOKIE_NAME=better_life_session

# File storage for medical documents
# Use your provider values: Supabase Storage, S3, R2, etc.
STORAGE_PROVIDER=
STORAGE_BUCKET=medical-records
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_ENDPOINT=

# Email / OTP delivery
EMAIL_FROM=no-reply@betterlife.health
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Optional analytics / monitoring
NEXT_PUBLIC_ANALYTICS_ID=
SENTRY_DSN=
